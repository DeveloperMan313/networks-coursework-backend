        <mxCell id="yjpsvXvvrqSAKndxfRyx-19" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;rounded=0;" value="Пины:&lt;div&gt;&lt;br&gt;&lt;div&gt;1 - Data Carrier Detect (DCD)&lt;div&gt;2 - Received Data (RXD)&lt;/div&gt;&lt;div&gt;3 - Transmit Data (TXD)&lt;/div&gt;&lt;div&gt;4 - Data Terminal Ready (DTR)&lt;/div&gt;&lt;div&gt;5 - Ground (GND) (не исп.)&lt;/div&gt;&lt;div&gt;6 - Data Set Ready (DSR) (не исп.)&lt;/div&gt;&lt;div&gt;7 - Request To Send (RTS)&lt;/div&gt;&lt;div&gt;8 - Clear To Send (CTS)&lt;/div&gt;&lt;div&gt;9 - Ring Indicator (RI) (не исп.)&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="180" width="200" x="40" y="180" as="geometry" />
        </mxCell>
        <mxCell id="yjpsvXvvrqSAKndxfRyx-21" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;rounded=0;" value="DTE-DTE соединения A -&amp;gt; B:&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;DTR -&amp;gt; DCD&lt;/div&gt;&lt;div&gt;TXD -&amp;gt; RXD&lt;/div&gt;&lt;div&gt;RTS -&amp;gt; CTS&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;B -&amp;gt; A аналогично&lt;/div&gt;" vertex="1">
